# Environment variables for Aquacommons OpenEnv Inference
# Copy this to .env and fill in your values for local development

# Hugging Face token (use a 'read' type token from https://huggingface.co/settings/tokens, required for OpenAI API access)
HF_TOKEN="your_hf_token_here"

# OpenAI API base URL (default is fine for OpenAI)
API_BASE_URL="https://router.huggingface.co/v1"

# Model name (default is gpt-4o-mini)
MODEL_NAME="Qwen/Qwen2.5-72B-Instruct"

# Task name (default is easy-calm-bay, can be overridden by evaluator)
TASK_NAME=easy-calm-bay
#Easy task= easy-calm-bay
#Medium task= medium-migrating-schools
#Hard task= hard-volatile-ocean 