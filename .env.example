# Environment variables for Aquacommons OpenEnv Inference
# Copy this to .env and fill in your values for local development.

# Hugging Face token (use a valid token from https://huggingface.co/settings/tokens)
HF_TOKEN="hf_your_huggingface_token_here"

# OpenAI API base URL for Hugging Face inference
API_BASE_URL="https://router.huggingface.co/v1"

# Model name to use for inference
MODEL_NAME="Qwen/Qwen2.5-72B-Instruct"

# Task name to run by default if no task argument is provided
TASK_NAME=easy-calm-bay
